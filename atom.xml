ss="code"><pre><span class="line">import &#x27;package:flutter/material.dart&#x27;;</span><br><span class="line">import &#x27;package:flutter_app/page/welcome.dart&#x27;;</span><br><span class="line">void main() =&gt; runApp(MaterialApp(</span><br><span class="line">      title: &#x27;导航演示1&#x27;,</span><br><span class="line">      home: Welcome(),</span><br><span class="line">    ));</span><br></pre></td></tr></table></figure>]]></content>
    
    
      
      
